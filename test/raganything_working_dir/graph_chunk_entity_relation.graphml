    <node id="California Institute of Technology">
      <data key="d0">California Institute of Technology</data>
      <data key="d1">organization</data>
      <data key="d2">Caltech is an academic institution affiliated with the Caltech-256 object category dataset.</data>
      <data key="d3">chunk-18ada958b761b3b461355a37d487ef5d</data>
