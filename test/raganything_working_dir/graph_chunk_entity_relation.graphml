      <data key="d6" />
    </node>
    <node id="Caltech-101">
      <data key="d0">Caltech-101</data>
      <data key="d1">data</data>
      <data key="d2">Caltech-101 is a dataset used to measure mean class recall in image classification tasks.&lt;SEP&gt;Caltech-101 is a dataset containing 9,000 images categorized into 102 classes, including 101 object categories and a background class, used for image classification benchmarking.&lt;SEP&gt;Caltech-101 is a dataset used to evaluate the performance of neural network models, where models are compared in the analysis.</data>
      <data key="d3">chunk-40bfade9d2720e8c40f7ccada6980ef7&lt;SEP&gt;chunk-1f5bdd5865b487e29cc5aa8228165cc7&lt;SEP&gt;chunk-4bd2f337bd598e8c48e820585a63127d</data>
