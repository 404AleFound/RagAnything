    <node id="Weights">
      <data key="d0">Weights</data>
      <data key="d1">data</data>
      <data key="d2">Weights are the parameters in neural networks that determine the strength of connections between neurons and are crucial for learning.</data>
      <data key="d3">chunk-d6f4d23968c5e45cadd7773c219289a0&lt;SEP&gt;chunk-8a54d3c176db1485ff70ae6846b62da3</data>
