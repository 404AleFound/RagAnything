      <data key="d5">1774858993</data>
      <data key="d6" />
    </node>
    <node id="Spatial Resolution">
      <data key="d0">Spatial Resolution</data>
      <data key="d1">concept</data>
      <data key="d2">The spatial resolution of feature maps is reduced in initial layers to decrease computational load.</data>
      <data key="d3">chunk-ec1e400414ae226381210995dc5442d4&lt;SEP&gt;chunk-0eea5a170983a0751ecda38142b90a95</data>
