      <data key="d5">1774858994</data>
      <data key="d6" />
    </node>
    <node id="Soft-Max Layer">
      <data key="d0">Soft-Max Layer</data>
      <data key="d1">content</data>
      <data key="d2">The soft-max layer is the final layer in the neural network that performs classification by computing class probabilities.</data>
      <data key="d3">chunk-23eb0012359dac75ed79e6c991260f55</data>
      <data key="d4">Very_Deep_Convolutional_Networks_for_Large-Scale_Image_Recognition_content_list.json</data>
