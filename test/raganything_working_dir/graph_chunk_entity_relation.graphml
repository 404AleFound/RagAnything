    </node>
    <node id="Horizontal Flipping">
      <data key="d0">Horizontal Flipping</data>
      <data key="d1">method</data>
      <data key="d2">Horizontal flipping is an augmentation method where images are flipped along the horizontal axis to artificially increase dataset variability.</data>
      <data key="d3">chunk-87402a1e4f355b9c0a09f090f3a60df6</data>
      <data key="d4">Very_Deep_Convolutional_Networks_for_Large-Scale_Image_Recognition_content_list.json</data>
