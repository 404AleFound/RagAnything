    </edge>
    <edge source="Net-E" target="Caltech-256">
      <data key="d7">1.0</data>
      <data key="d8">Net-E outperforms the state of the art (Chatfield et al., 2014) on Caltech-256 by a large margin, 8.6%.</data>
      <data key="d9">performance</data>
      <data key="d10">chunk-40bfade9d2720e8c40f7ccada6980ef7</data>
      <data key="d11">Very_Deep_Convolutional_Networks_for_Large-Scale_Image_Recognition_content_list.json</data>
